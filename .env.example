# Copy to .env and fill in. docker-compose.yml reads this automatically.

# Secret used to sign session cookies. Generate one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# If left empty, a random key is generated on every container start, which
# logs everyone out whenever the container restarts/redeploys.
SESSION_SECRET_KEY=

# Set to false once everyone who should have an account has registered, to
# stop anyone else from signing up. Existing accounts can still log in.
REGISTRATION_ENABLED=true
